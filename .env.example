# Скопируй в .env и заполни своими значениями (Supabase → Project Settings → API).
# Без этих ключей приложение работает на статических данных (src/data/*) — ничего не ломается.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

ADMIN_PASSWORD=

# Опционально (Фаза 4):
# VITE_POSTHOG_KEY=
# VITE_SENTRY_DSN=

# Только для serverless / Vercel Function. Не использовать во frontend:
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=

# Cloudflare R2 / Worker secrets. Не использовать во frontend:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=

# Cloudflare D1 API for Vercel Functions:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_D1_DATABASE_ID=
# CLOUDFLARE_API_TOKEN=
